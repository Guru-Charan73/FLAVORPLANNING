<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    
    <Popover title="{localModel>/PopoverConfig/Title}" contentWidth="800px" placement="Auto">
        <content>
            <Table id="idDocDetailsTable" 
                   mode="MultiSelect" 
                   items="{localModel>/SelectedItems}">
                <columns>
                    <Column><Text text="Category"/></Column>
                    <Column><Text text="Prod Version"/></Column>
                    <Column><Text text="{localModel>/PopoverConfig/Col1Label}"/></Column>
                    <Column><Text text="{localModel>/PopoverConfig/DocColLabel}"/></Column>
                    <Column><Text text="Line Item"/></Column>
                    <Column><Text text="Material"/></Column>
                    <Column><Text text="Quantity"/></Column>
                </columns>
                <items>
                    <ColumnListItem>
                        <cells>
                            <Text text="{localModel>Category}"/>
                            <Text text="{localModel>ProdVersion}"/>
                            <Text text="{localModel>Col1Value}"/>
                            <Text text="{localModel>DocNumber}"/>
                            <Text text="{localModel>DocItem}"/>
                            <Text text="{localModel>Material}"/>
                            <Text text="{localModel>Quantity}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        
        <footer>
            <Toolbar>
                <ToolbarSpacer/>
                <Button 
                    text="PR to PO" 
                    type="Emphasized" 
                    icon="sap-icon://cart-3"
                    visible="{= ${localModel>/PopoverConfig/DocColLabel} === 'Purchase Req' }"
                    press=".onConvertPrToPo" />
                <Button text="Close" press=".onCloseDocFragment" />
            </Toolbar>
        </footer>
    </Popover>
</core:FragmentDefinition>