<core:FragmentDefinition 
    xmlns="sap.m" 
    xmlns:core="sap.ui.core">
    <Popover title="{localModel>/PopoverConfig/Title}" placement="Auto" contentWidth="1200px" class="sapUiContentPadding">
        
        <endButton>
            <Button text="Close" press=".onCloseDocFragment" type="Reject" />
        </endButton>

        <Table id="dynamicDetailsTable" items="{localModel>/SelectedItems}">
            <columns>
                <Column><Text text="Category" /></Column>
                <Column><Text text="MRP Element" /></Column>
                <Column><Text text="Prod Version" /></Column>
                
                <Column><Text text="{localModel>/PopoverConfig/Col1Label}" /></Column>
                <Column><Text text="{localModel>/PopoverConfig/DocColLabel}" /></Column>
                
                <Column width="5rem"><Text text="Line Item" /></Column>
                <Column><Text text="Material" /></Column>
                <Column><Text text="Description" /></Column>
                <Column hAlign="End"><Text text="Quantity" /></Column>
            </columns>
            <items>
                <ColumnListItem>
                    <cells>
                        <Text text="{localModel>Category}" />
                        <Text text="{localModel>MRPElementText}" />
                        <Text text="{localModel>ProdVersion}" />
                        
                        <Text text="{localModel>Col1Value}" />
                        <Text text="{localModel>DocNumber}" />
                        <Text text="{localModel>DocItem}" />
                        <Text text="{localModel>Material}" />
                        <Text text="{localModel>Description}" />
                        <Text text="{
                            path: 'localModel>Quantity',
                            type: 'sap.ui.model.type.Float',
                            formatOptions: { minFractionDigits: 3, maxFractionDigits: 3 }
                        }" /> 
                    </cells>
                </ColumnListItem>
            </items>
        </Table>
    </Popover>
</core:FragmentDefinition>